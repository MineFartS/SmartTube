{
    
    "deadCodeDetector.exclude": [
        ".gradle",
        "**/build",
        "**/assets/nsigsolver/*.js"
    ],
    "deadCodeDetector.analyzeOnSave": false,
    "deadCodeDetector.confidenceThreshold": "high",

    "files.exclude": {
        ".gradle": true,
        ".vscode": true,
        "**/build": true,
        "lib": true
    },

    "kotlin.inlayHints.parameterHints": false,
    "kotlin.inlayHints.typeHints": false,
    
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.dependency.enableDependencyCheckup": false,
    "java.import.maven.enabled": false,
    "java.configuration.detectJdksAtStart": true,
    "java.configuration.runtimes": [{
        "name": "JavaSE-17",
        "path": "${workspaceFolder}/lib/jdk/",
        "default": true
    }],

    "terminal.integrated.env.windows": {
        "JAVA_HOME": "${workspaceFolder}/lib/jdk",
        "PATH": "${workspaceFolder}/lib/jdk/bin;${workspaceFolder}/sdk/platform-tools;${env:PATH}"
    },
    "notebook.defaultFormatter": "redhat.java",

}