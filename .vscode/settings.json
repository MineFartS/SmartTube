{
    
    "deadCodeDetector.exclude": [
        ".gradle",
        "**/build",
        "**/assets/nsigsolver/*.js"
    ],
    "deadCodeDetector.analyzeOnSave": false,
    "deadCodeDetector.confidenceThreshold": "high",

    "files.exclude": {
        ".vscode": true,
        "**/.gradle": true,
        "**/build": true,
        "aar": true,
        "lib/ejs": true,
        "lib/jdk17": true,
        "lib/pidcat": true,
        "lib/py314": true,
        "lib/sdk": true,
    },

    "kotlin.inlayHints.parameterHints": false,
    "kotlin.inlayHints.typeHints": false,
    
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.dependency.enableDependencyCheckup": false,
    "java.import.maven.enabled": false,
    "java.configuration.detectJdksAtStart": true,
    "java.configuration.runtimes": [{
        "name": "JavaSE-17",
        "path": "${workspaceFolder}/lib/jdk17/",
        "default": true
    }],

    "terminal.integrated.env.windows": {
        "JAVA_HOME": "${workspaceFolder}/lib/jdk17/",
        "PATH": "${workspaceFolder}/lib/jdk17/bin;${workspaceFolder}/lib/sdk/platform-tools;${env:PATH}"
    },
    "notebook.defaultFormatter": "redhat.java",

}